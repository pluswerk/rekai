{
    "name": "pluswerk/rekai",
    "description": "TYPO3 extension to integrate rek.ai recommendations, Q&A and search autocomplete",
    "type": "typo3-cms-extension",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "+Pluswerk AG",
            "email": "mike.streibl@pluswerk.digital",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "typo3/cms-core": "^12.4 || ^13.4 || ^14.0",
        "typo3/cms-extbase": "^12.4 || ^13.4 || ^14.0",
        "typo3/cms-fluid": "^12.4 || ^13.4 || ^14.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Pluswerk\\Rekai\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pluswerk\\Rekai\\Tests\\": "Tests/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "rekai"
        }
    }
}
