plugin.tx_rekai_recommendations {
    view {
        templateRootPaths {
            0 = EXT:rekai/Resources/Private/Templates/
        }
        partialRootPaths {
            0 = EXT:rekai/Resources/Private/Partials/
            10 = EXT:fluid_styled_content/Resources/Private/Partials/
        }
        layoutRootPaths {
            0 = EXT:rekai/Resources/Private/Layouts/
            10 = EXT:fluid_styled_content/Resources/Private/Layouts/
        }
    }
    settings {
        nrOfHits = 10
        renderStyle = list
        showImage = 0
        showIngress = 0
        cols = 2
        subtree =
        excludeTree =
        allowedLangs =
        tags =
    }
}

