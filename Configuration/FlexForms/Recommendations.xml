<?xml version="1.0" encoding="utf-8" standalone="yes" ?>
<T3DataStructure>
    <sheets>
        <sDEF>
            <ROOT>
                <sheetTitle>General</sheetTitle>
                <type>array</type>
                <el>
                    <settings.nrOfHits>
                        <label>Number of Hits</label>
                        <config>
                            <type>number</type>
                            <range>
                                <lower>1</lower>
                                <upper>100</upper>
                            </range>
                            <default>10</default>
                        </config>
                    </settings.nrOfHits>
                    <settings.renderStyle>
                        <label>Render Style</label>
                        <config>
                            <type>select</type>
                            <renderType>selectSingle</renderType>
                            <items>
                                <numIndex index="0">
                                    <numIndex index="0">List</numIndex>
                                    <numIndex index="1">list</numIndex>
                                </numIndex>
                                <numIndex index="1">
                                    <numIndex index="0">Pills</numIndex>
                                    <numIndex index="1">pills</numIndex>
                                </numIndex>
                                <numIndex index="2">
                                    <numIndex index="0">Advanced</numIndex>
                                    <numIndex index="1">advanced</numIndex>
                                </numIndex>
                            </items>
                            <default>list</default>
                        </config>
                    </settings.renderStyle>
                    <settings.showImage>
                        <label>Show Image</label>
                        <config>
                            <type>check</type>
                            <default>0</default>
                        </config>
                    </settings.showImage>
                    <settings.showIngress>
                        <label>Show Ingress / Teaser</label>
                        <config>
                            <type>check</type>
                            <default>0</default>
                        </config>
                    </settings.showIngress>
                    <settings.headerText>
                        <label>Header Text</label>
                        <config>
                            <type>input</type>
                        </config>
                    </settings.headerText>
                    <settings.headerHeadingLevel>
                        <label>Header Heading Level</label>
                        <config>
                            <type>select</type>
                            <renderType>selectSingle</renderType>
                            <items>
                                <numIndex index="0">
                                    <numIndex index="0">h2</numIndex>
                                    <numIndex index="1">h2</numIndex>
                                </numIndex>
                                <numIndex index="1">
                                    <numIndex index="0">h3</numIndex>
                                    <numIndex index="1">h3</numIndex>
                                </numIndex>
                                <numIndex index="2">
                                    <numIndex index="0">h4</numIndex>
                                    <numIndex index="1">h4</numIndex>
                                </numIndex>
                                <numIndex index="3">
                                    <numIndex index="0">h5</numIndex>
                                    <numIndex index="1">h5</numIndex>
                                </numIndex>
                                <numIndex index="4">
                                    <numIndex index="0">h6</numIndex>
                                    <numIndex index="1">h6</numIndex>
                                </numIndex>
                            </items>
                            <default>h2</default>
                        </config>
                    </settings.headerHeadingLevel>
                    <settings.cols>
                        <label>Columns (for advanced/grid render style)</label>
                        <config>
                            <type>number</type>
                            <range>
                                <lower>1</lower>
                                <upper>6</upper>
                            </range>
                            <default>2</default>
                        </config>
                    </settings.cols>
                </el>
            </ROOT>
        </sDEF>
        <sFilter>
            <ROOT>
                <sheetTitle>Filter</sheetTitle>
                <type>array</type>
                <el>
                    <settings.subtree>
                        <label>Subtree (comma-separated relative paths, e.g. /news/,/blog/)</label>
                        <config>
                            <type>input</type>
                        </config>
                    </settings.subtree>
                    <settings.excludeTree>
                        <label>Exclude Tree (comma-separated relative paths)</label>
                        <config>
                            <type>input</type>
                        </config>
                    </settings.excludeTree>
                    <settings.allowedLangs>
                        <label>Allowed Languages (comma-separated language codes, e.g. de,en)</label>
                        <config>
                            <type>input</type>
                        </config>
                    </settings.allowedLangs>
                    <settings.tags>
                        <label>Tags (comma-separated)</label>
                        <config>
                            <type>input</type>
                        </config>
                    </settings.tags>
                </el>
            </ROOT>
        </sFilter>
    </sheets>
</T3DataStructure>
