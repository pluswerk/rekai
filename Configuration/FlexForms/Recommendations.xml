<?xml version="1.0" encoding="utf-8" standalone="yes" ?>
<T3DataStructure>
    <sheets>
        <sDEF>
            <ROOT>
                <sheetTitle>General</sheetTitle>
                <type>array</type>
                <el>
                    <settings.nrOfHits>
                        <label>Number of Hits</label>
                        <config>
                            <type>number</type>
                            <range>
                                <lower>1</lower>
                                <upper>100</upper>
                            </range>
                            <default>10</default>
                        </config>
                    </settings.nrOfHits>
                    <settings.renderStyle>
                        <label>Render Style</label>
                        <config>
                            <type>select</type>
                            <renderType>selectSingle</renderType>
                            <items>
                                <numIndex index="0" type="array">
                                    <label>List</label>
                                    <value>list</value>
                                </numIndex>
                                <numIndex index="1" type="array">
                                    <label>Pills</label>
                                    <value>pills</value>
                                </numIndex>
                                <numIndex index="2" type="array">
                                    <label>Advanced</label>
                                    <value>advanced</value>
                                </numIndex>
                            </items>
                            <default>list</default>
                        </config>
                    </settings.renderStyle>
                    <settings.showImage>
                        <label>Show Image</label>
                        <config>
                            <type>check</type>
                            <default>0</default>
                        </config>
                    </settings.showImage>
                    <settings.showIngress>
                        <label>Show Ingress / Teaser</label>
                        <config>
                            <type>check</type>
                            <default>0</default>
                        </config>
                    </settings.showIngress>
                    <settings.headerText>
                        <label>Header Text</label>
                        <config>
                            <type>input</type>
                        </config>
                    </settings.headerText>
                    <settings.headerHeadingLevel>
                        <label>Header Heading Level</label>
                        <config>
                            <type>select</type>
                            <renderType>selectSingle</renderType>
                            <items>
                                <numIndex index="0" type="array">
                                    <label>h2</label>
                                    <value>h2</value>
                                </numIndex>
                                <numIndex index="1" type="array">
                                    <label>h3</label>
                                    <value>h3</value>
                                </numIndex>
                                <numIndex index="2" type="array">
                                    <label>h4</label>
                                    <value>h4</value>
                                </numIndex>
                                <numIndex index="3" type="array">
                                    <label>h5</label>
                                    <value>h5</value>
                                </numIndex>
                                <numIndex index="4" type="array">
                                    <label>h6</label>
                                    <value>h6</value>
                                </numIndex>
                            </items>
                            <default>h2</default>
                        </config>
                    </settings.headerHeadingLevel>
                    <settings.cols>
                        <label>Columns (for advanced/grid render style)</label>
                        <config>
                            <type>number</type>
                            <range>
                                <lower>1</lower>
                                <upper>6</upper>
                            </range>
                            <default>2</default>
                        </config>
                    </settings.cols>
                </el>
            </ROOT>
        </sDEF>
        <sFilter>
            <ROOT>
                <sheetTitle>Filter</sheetTitle>
                <type>array</type>
                <el>
                    <settings.subtree>
                        <label>Subtree (comma-separated relative paths, e.g. /news/,/blog/)</label>
                        <config>
                            <type>input</type>
                        </config>
                    </settings.subtree>
                    <settings.excludeTree>
                        <label>Exclude Tree (comma-separated relative paths)</label>
                        <config>
                            <type>input</type>
                        </config>
                    </settings.excludeTree>
                    <settings.allowedLangs>
                        <label>Allowed Languages (comma-separated language codes, e.g. de,en)</label>
                        <config>
                            <type>input</type>
                        </config>
                    </settings.allowedLangs>
                    <settings.tags>
                        <label>Tags (comma-separated)</label>
                        <config>
                            <type>input</type>
                        </config>
                    </settings.tags>
                </el>
            </ROOT>
        </sFilter>
    </sheets>
</T3DataStructure>
